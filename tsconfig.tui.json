{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2023"],
    "jsx": "preserve",
    "jsxImportSource": "@opentui/solid",
    "outDir": "dist",
    "rootDir": "src",
    "noEmit": false,
    "noEmitOnError": false,
    "removeComments": false,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowImportingTsExtensions": false,
    "types": ["node"]
  },
  "include": ["src/tui.tsx"]
}
